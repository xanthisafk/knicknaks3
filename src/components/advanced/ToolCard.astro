---
import type { ToolDefinition } from "@/tools/_types";
import { STATUS_INFO } from "@/tools/_types";

interface Props {
  tool: ToolDefinition;
}
const { tool } = Astro.props;
---

<a
  href={`/tools/${tool.slug}`}
  class="group flex flex-col p-4 md:p-5 rounded-lg bg-(--surface-elevated) border border-(--border-default)
no-underline transition-transform duration-150 hover:border-(--border-hover) hover:shadow-md
tool-card relative overflow-visible"
  data-tool-slug={tool.slug}
  data-tool-status={tool.status || ""}
>
  <!-- Status ribbon -->
  {
    tool.status && (
      <div class="absolute -top-px -right-px flex flex-col items-center pointer-events-none">
        <div class="flex items-center justify-center gap-1 px-2 pt-1.5 pb-0 bg-(--surface-secondary) border border-b-0 border-(--border-default) min-w-[44px]">
          <span class="text-xs leading-none font-emoji">
            {STATUS_INFO[tool.status].icon}
          </span>
          <span class="text-[10px] uppercase font-bold tracking-widest text(--text-secondary) leading-none">
            {STATUS_INFO[tool.status].label}
          </span>
        </div>
        <div
          class="w-full"
          style="height:8px;background:var(--surface-secondary);border-left:1px solid var(--border-default);border-right:1px solid var(--border-default);clip-path:polygon(0% 0%,100% 0%,100% 100%,50% 55%,0% 100%);"
        />
      </div>
    )
  }

  <!-- Card body -->
  <div class="flex items-start gap-3 flex-1 group">
    <span class="text-2xl shrink-0 mt-0.5 font-emoji">{tool.icon}</span>
    <div>
      <span
        class="font-emoji text-6xl transition-all duration-300 absolute right-0 translate-x-[25px] rotate-12 opacity-0 group-hover:translate-x-[-10px] group-hover:opacity-30 group-hover:-rotate-12"
      >
        {tool.icon}
      </span>
      <h3
        class="text-sm font-semibold text(--text-primary) group-hover:text-primary-600"
        style="font-family: var(--font-heading)"
      >
        {tool.name}
      </h3>
      <p class="text-xs text(--text-secondary) mt-1 line-clamp-2">
        {tool.description}
      </p>
      <div
        class="offline-badge hidden items-center gap-1 mt-2 px-1.5 py-0.5 rounded-full text-xs font-bold uppercase tracking-wider bg-green-100 text-green-700 border border-green-300 dark:bg-green-900/40 dark:text-green-400 dark:border-green-700 shadow-sm"
        title="Available offline"
        aria-label="Available offline"
      >
        <span>✓</span>
        <span>offline</span>
      </div>
    </div>
  </div>
</a>
