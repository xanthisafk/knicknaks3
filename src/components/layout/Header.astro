---
interface Props {
  activeTab?: "tools" | "blog";
}

const { activeTab } = Astro.props;
---

<header
  class="sticky top-0 z-40 bg-(--surface-bg)/80 backdrop-blur-lg border-b border-(--border-default)"
>
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 no-underline group">
        <span
          id="yoyo-icon"
          class="text-2xl transition-transform duration-300 inline-block font-emoji"
          style="will-change: transform;">🪀</span
        >
        <span
          class="text-xl font-bold tracking-tight text-(--text-primary) font-brand"
        >
          Knicknaks
        </span>
      </a>
      <div class="flex items-center gap-4 text-sm font-medium">
        <a
          href="/"
          class={`${activeTab === "tools" ? "text-primary-600 border-primary-500" : "text-(--text-secondary) hover:text-(--text-primary) border-transparent"} border-b-2 py-5 transition-colors`}
          >Tools</a
        >
        <a
          href="/blog"
          class={`${activeTab === "blog" ? "text-primary-600 border-primary-500" : "text-(--text-secondary) hover:text-(--text-primary) border-transparent"} border-b-2 py-5 transition-colors`}
          >Blog</a
        >

        <div class="w-px h-4 bg-[--border-default] mx-1"></div>

        <!-- Theme switcher: icon cycles on click, chevron opens picker -->
        <div class="flex items-center" id="theme-switcher-wrapper">
          <button
            id="theme-cycle-btn"
            type="button"
            class="w-8 h-8 text-lg flex items-center justify-center rounded-l-md text-(--text-secondary) hover:text-(--text-primary) transition-colors relative cursor-pointer"
            aria-label="Cycle theme"
            title="Click to cycle theme"
          >
            <span
              id="theme-current-icon"
              class="font-emoji transition-all duration-300 absolute">🌞</span
            >
          </button>

          <div class="relative">
            <button
              id="theme-picker-btn"
              type="button"
              class="w-5 h-8 flex items-center justify-center rounded-r-md text-(--text-secondary) hover:text-(--text-primary) transition-colors cursor-pointer opacity-50 hover:opacity-100"
              aria-label="Pick theme"
              title="Choose a theme"
            >
              <svg
                width="10"
                height="6"
                viewBox="0 0 10 6"
                fill="currentColor"
                class="transition-transform duration-200"
                id="theme-chevron"
              >
                <path
                  d="M0.5 0.5L5 5L9.5 0.5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  fill="none"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>

            <!-- Dropdown -->
            <div
              id="theme-dropdown"
              class="absolute right-0 top-full mt-2 hidden"
              style="z-index: 100;"
            >
              <div
                class="rounded-xl border border-(--border-default) bg-(--surface-bg) shadow-xl backdrop-blur-xl overflow-hidden"
                style="min-width: 140px;"
              >
                <div class="p-1.5" id="theme-options-list">
                  <!-- Populated by JS -->
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  /* ── Dropdown animation ── */
  #theme-dropdown {
    opacity: 0;
    transform: translateY(-6px) scale(0.97);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease;
    pointer-events: none;
  }
  #theme-dropdown.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
    display: block !important;
  }

  /* Theme option button */
  .theme-option-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 6px 10px;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    transition:
      background 0.1s,
      color 0.1s;
    white-space: nowrap;
    text-align: left;
  }
  .theme-option-btn:hover {
    background: var(--border-default, rgba(128, 128, 128, 0.12));
    color: var(--text-primary);
  }
  .theme-option-btn.active {
    background: var(--border-default, rgba(128, 128, 128, 0.18));
    color: var(--text-primary);
    font-weight: 700;
  }
  .theme-option-icon {
    font-size: 1rem;
    line-height: 1;
  }

  /* Chevron open state */
  #theme-chevron.rotated {
    transform: rotate(180deg);
  }

  /* ── Current icon bounce-in animation ── */
  @keyframes iconPop {
    0% {
      transform: scale(0.5) rotate(-30deg);
      opacity: 0;
    }
    60% {
      transform: scale(1.25) rotate(8deg);
      opacity: 1;
    }
    100% {
      transform: scale(1) rotate(0deg);
      opacity: 1;
    }
  }
  .icon-pop {
    animation: iconPop 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
</style>

<script is:inline>
  // ─────────────────────────────────────────────────────────────────────────
  // THEMES CONFIG — add new entries here to extend theme support
  // Each key must match a `data-theme` value handled by your CSS.
  // ─────────────────────────────────────────────────────────────────────────
  const THEMES = {
    light: { icon: "🌞", label: "Light" },
    dark: { icon: "🌚", label: "Dark" },
    forest: { icon: "🌲", label: "Forest" },
    ocean: { icon: "🌊", label: "Ocean" },
    sunset: { icon: "🌅", label: "Sunset" },
    sakura: { icon: "🌸", label: "Sakura" },
    midnight: { icon: "🌙", label: "Midnight" },
    aurora: { icon: "🌌", label: "Aurora" },
    desert: { icon: "🏜️", label: "Desert" },
    lavender: { icon: "🪻", label: "Lavender" },
    arctic: { icon: "🧊", label: "Arctic" },
    cyberpunk: { icon: "🟣", label: "Cyberpunk" },
    emerald: { icon: "💚", label: "Emerald" },
    rose: { icon: "🌹", label: "Rose" },
    matcha: { icon: "🍵", label: "Matcha" },
    volcano: { icon: "🌋", label: "Volcano" },
  };

  const THEME_KEYS = Object.keys(THEMES);
  const STORAGE_KEY = "knicknaks-theme";

  // ── Helpers ───────────────────────────────────────────────────────────────
  function getCurrentTheme() {
    return document.documentElement.getAttribute("data-theme") || THEME_KEYS[0];
  }

  function applyTheme(key) {
    document.documentElement.setAttribute("data-theme", key);
    localStorage.setItem(STORAGE_KEY, key);
    updateUI(key);
  }

  function cycleTheme() {
    const current = getCurrentTheme();
    const idx = THEME_KEYS.indexOf(current);
    const next = THEME_KEYS[(idx + 1) % THEME_KEYS.length];
    applyTheme(next);
  }

  function updateUI(activeKey) {
    // Update the main icon with a pop animation
    const iconEl = document.getElementById("theme-current-icon");
    if (iconEl) {
      iconEl.classList.remove("icon-pop");
      // Force reflow so the animation re-triggers
      void iconEl.offsetWidth;
      iconEl.textContent = THEMES[activeKey]?.icon ?? "🎨";
      iconEl.classList.add("icon-pop");
    }

    // Highlight active option in dropdown
    document.querySelectorAll(".theme-option-btn").forEach((btn) => {
      btn.classList.toggle("active", btn.dataset.theme === activeKey);
    });
  }

  // ── Build dropdown options ────────────────────────────────────────────────
  function buildDropdown() {
    const list = document.getElementById("theme-options-list");
    if (!list) return;
    list.innerHTML = "";
    THEME_KEYS.forEach((key) => {
      const { icon, label } = THEMES[key];
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "theme-option-btn";
      btn.dataset.theme = key;
      btn.innerHTML = `<span class="theme-option-icon font-emoji">${icon}</span><span>${label}</span>`;
      btn.addEventListener("click", () => {
        applyTheme(key);
        closeDropdown();
      });
      list.appendChild(btn);
    });
  }

  // ── Dropdown open/close ───────────────────────────────────────────────────
  let dropdownOpen = false;

  function openDropdown() {
    const dd = document.getElementById("theme-dropdown");
    const chevron = document.getElementById("theme-chevron");
    if (!dd) return;
    dd.classList.remove("hidden");
    // Trigger transition on next frame
    requestAnimationFrame(() => dd.classList.add("open"));
    chevron?.classList.add("rotated");
    dropdownOpen = true;
  }

  function closeDropdown() {
    const dd = document.getElementById("theme-dropdown");
    const chevron = document.getElementById("theme-chevron");
    if (!dd) return;
    dd.classList.remove("open");
    chevron?.classList.remove("rotated");
    dropdownOpen = false;
    // Hide after transition completes
    setTimeout(() => {
      if (!dropdownOpen) dd.classList.add("hidden");
    }, 160);
  }

  function toggleDropdown() {
    dropdownOpen ? closeDropdown() : openDropdown();
  }

  // ── Init ──────────────────────────────────────────────────────────────────
  document.addEventListener("DOMContentLoaded", () => {
    buildDropdown();

    const current = localStorage.getItem(STORAGE_KEY) || THEME_KEYS[0];
    applyTheme(current);

    // Cycle on main icon click
    document
      .getElementById("theme-cycle-btn")
      ?.addEventListener("click", cycleTheme);

    // Toggle dropdown on chevron click
    document
      .getElementById("theme-picker-btn")
      ?.addEventListener("click", (e) => {
        e.stopPropagation();
        toggleDropdown();
      });

    // Close dropdown on outside click
    document.addEventListener("click", (e) => {
      if (
        dropdownOpen &&
        !document.getElementById("theme-switcher-wrapper")?.contains(e.target)
      ) {
        closeDropdown();
      }
    });

    // ── Yoyo animation ──────────────────────────────────────────────────────
    initYoyoMotion();
  });

  // ── Yoyo (unchanged) ─────────────────────────────────────────────────────
  function initYoyoMotion() {
    const yoyo = document.getElementById("yoyo-icon");
    if (!yoyo) return;

    function lerp(a, b, t) {
      return a + (b - a) * t;
    }

    function tryDeviceOrientation() {
      let targetAngle = 0,
        currentAngle = 0,
        rafId = null;
      function onOrientation(e) {
        const gamma = Math.max(-45, Math.min(45, e.gamma || 0));
        targetAngle = -gamma;
      }
      function tick() {
        currentAngle = lerp(currentAngle, targetAngle, 0.12);
        yoyo.style.transform = `rotate(${currentAngle.toFixed(2)}deg)`;
        rafId = requestAnimationFrame(tick);
      }
      window.addEventListener("deviceorientation", onOrientation, true);
      tick();
      return () => {
        window.removeEventListener("deviceorientation", onOrientation, true);
        cancelAnimationFrame(rafId);
      };
    }

    function startDesktopWobble() {
      let targetAngle = 0,
        currentAngle = 0,
        rafId = null;
      let lastSwitch = performance.now();
      const AMPLITUDE = 14,
        HOLD_MS = 1600;
      let direction = 1;
      function tick(now) {
        if (now - lastSwitch > HOLD_MS) {
          direction *= -1;
          targetAngle = direction * AMPLITUDE;
          lastSwitch = now;
        }
        currentAngle = lerp(currentAngle, targetAngle, 0.035);
        yoyo.style.transform = `rotate(${currentAngle.toFixed(2)}deg)`;
        rafId = requestAnimationFrame(tick);
      }
      rafId = requestAnimationFrame(tick);
      return () => cancelAnimationFrame(rafId);
    }

    const isMobile =
      /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) ||
      ("ontouchstart" in window && navigator.maxTouchPoints > 0);

    if (isMobile && typeof DeviceOrientationEvent !== "undefined") {
      if (typeof DeviceOrientationEvent.requestPermission === "function") {
        yoyo.style.cursor = "pointer";
        yoyo.title = "Tap to enable tilt";
        const startWobble = startDesktopWobble();
        yoyo.addEventListener(
          "click",
          () => {
            DeviceOrientationEvent.requestPermission()
              .then((state) => {
                if (state === "granted") {
                  startWobble();
                  tryDeviceOrientation();
                  yoyo.style.cursor = "";
                  yoyo.title = "";
                }
              })
              .catch(() => {});
          },
          { once: true },
        );
      } else {
        tryDeviceOrientation();
      }
    } else {
      startDesktopWobble();
    }
  }
</script>
