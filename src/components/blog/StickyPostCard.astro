---
import { Card } from "@/components/layout/Layout";

interface Props {
  post: any;
}

const { post } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(post.data.publishDate);
---

<a href={`/blog/${post.id}`} class="block group h-full relative">
  <Card
    className="h-full flex flex-col doodle-border transition-all duration-300 group-hover:-translate-y-2 group-hover:shadow-xl bg-gradient-to-br from-[--surface-secondary] to-[--surface-elevated] border-2 border-[--color-primary-500]"
  >
    <div
      class="absolute -top-3 -right-3 z-10 w-8 h-8 flex items-center justify-center bg-[--surface-bg] rounded-full border border-[--border-default] shadow-sm transform rotate-12"
      title="Sticky Post"
    >
      📌
    </div>
    {
      post.data.coverImage && (
        <div class="aspect-video mb-4 overflow-hidden rounded-[--radius-md] border border-[--border-default]">
          <img
            src={post.data.coverImage}
            alt={post.data.title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        </div>
      )
    }
    <div class="flex-1 flex flex-col">
      <div class="flex gap-2 mb-3">
        {
          post.data.tags
            .slice(0, 2)
            .map((tag: string) => (
              <span class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider bg-[--surface-bg] text-[--text-secondary] border border-[--border-default] rounded-[--radius-sm]">
                {tag}
              </span>
            ))
        }
      </div>
      <h2
        class="text-xl font-bold font-[family-name:var(--font-heading)] text-[--text-primary] group-hover:text-[--color-primary-500] transition-colors line-clamp-2 leading-snug"
      >
        {post.data.title}
      </h2>
      <p
        class="mt-3 text-sm text-[--text-secondary] line-clamp-3 flex-1 leading-relaxed"
      >
        {post.data.description}
      </p>
      <div
        class="mt-6 pt-4 border-t border-[--border-default] flex items-center justify-between text-xs text-[--text-tertiary]"
      >
        <span>{formattedDate}</span>
        <span
          class="font-semibold text-[--color-primary-500] group-hover:translate-x-1 transition-transform"
        >
          Read More →
        </span>
      </div>
    </div>
  </Card>
</a>
