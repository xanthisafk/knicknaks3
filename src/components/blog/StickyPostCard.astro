---
import { Card } from "@/components/layout/Layout";

interface Props {
  post: any;
}

const { post } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(post.data.publishDate);
---

<a href={`/blog/${post.id}`} class="block group h-full relative">
  <Card
    className="h-full mt-4 flex flex-col doodle-border transition-all duration-300 bg-linear-to-brrom-(--surface-secondary) to-(--surface-elevated) border-2 group-hover:border-primary-500"
  >
    {
      post.data.coverImage && (
        <div class="aspect-video mb-4 overflow-hidden rounded-md border border-(--border-default)">
          <img
            src={post.data.coverImage}
            alt={post.data.title}
            class="w-full h-full object-cover"
            transition:name="image"
          />
        </div>
      )
    }
    <div class="flex-1 flex flex-col">
      <div class="flex gap-2 mb-3">
        {
          post.data.tags.slice(0, 2).map((tag: string, index: number) => (
            <span
              transition:name={`tag-${index}`}
              class="px-2 py-0.5 text-xs font-bold uppercase tracking-wider bg-(--surface-bg) text-(--text-secondary) border border-(--border-default) rounded-sm"
            >
              {tag}
            </span>
          ))
        }
      </div>
      <h2
        transition:name="title"
        class="text-xl font-bold font-(family-name:var(--font-heading)) text-(--text-primary) group-hover:text-primary-500 transition-colors line-clamp-2 leading-snug"
      >
        {post.data.title}
      </h2>
      <p
        class="mt-3 text-sm text-(--text-secondary) line-clamp-3 flex-1 leading-relaxed"
      >
        {post.data.description}
      </p>
      <div
        class="mt-6 pt-4 border-t border-(--border-default) flex items-center justify-between text-xs text-(--text-tertiary)"
      >
        <span>{formattedDate}</span>
        <span class="font-semibold text-primary-500"> Read More → </span>
      </div>
    </div>
  </Card>
</a>
