---
import { Card } from "@/components/layout/Layout";

interface Props {
  post: any;
}

const { post } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(post.data.publishDate);
---

<a href={`/blog/${post.id}`} class="block group mb-12 relative">
  <!-- Decorative background element for featured -->
  <div
    class="absolute -inset-2 bg-linear-to-tr from-primary-500 to-primary-400 opacity-20 rotate-1 rounded-xl -z-10 group-hover:rotate-0 transition-transform duration-500"
  >
  </div>

  <Card
    className="flex flex-col md:flex-row gap-6 md:gap-8 p-6 md:p-8 doodle-border border-2 border-(--border-default) bg-(--surface-elevated) overflow-hidden shadow-lg group-hover:shadow-xl transition-all duration-300"
  >
    {
      post.data.coverImage && (
        <div class="w-full md:w-1/2 aspect-video md:aspect-auto overflow-hidden rounded-lg border border-(--border-default) relative text-0">
          <span class="absolute top-4 left-4 z-10 px-3 py-1.5 bg-primary-500 text-white text-xs font-bold uppercase tracking-widest rounded-full shadow-md transform -rotate-3">
            <span class="font-emoji">✨</span> Featured
          </span>
          <img
            src={post.data.coverImage}
            alt={post.data.title}
            class="w-full h-full object-cover"
          />
        </div>
      )
    }
    <div class="w-full md:w-1/2 flex flex-col justify-center">
      <div class="flex flex-wrap gap-2 mb-4">
        {
          post.data.tags.map((tag: string) => (
            <span class="px-2 py-1 text-xs font-bold uppercase tracking-wider bg-(--surface-secondary) text-(--text-secondary) border border-(--border-default) rounded-sm">
              {tag}
            </span>
          ))
        }
      </div>
      <h2
        class="text-3xl md:text-4xl font-extrabold font-heading text-(--text-primary) hover:text-primary-500 transition-colors leading-tight mb-4"
      >
        {post.data.title}
      </h2>
      <p
        class="text-base md:text-lg text-(--text-secondary) leading-relaxed mb-6 line-clamp-3"
      >
        {post.data.description}
      </p>

      <div
        class="mt-auto flex items-center justify-between text-sm text-(--text-tertiary) font-medium pt-4 border-t border-(--border-default)"
      >
        <div class="flex items-center gap-2">
          <span class="text-(--text-primary) font-bold">{post.data.author}</span
          >
          <span class="opacity-50">•</span>
          <span>{formattedDate}</span>
        </div>
        <span class="font-bold text-primary-500 inline-block">
          Read Article →
        </span>
      </div>
    </div>
  </Card>
</a>
