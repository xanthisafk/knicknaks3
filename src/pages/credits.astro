---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
---

<BaseLayout
  title="Credits — Knicknaks"
  description="Credits for open source libraries and resources used in Knicknaks."
>
  <div class="min-h-screen flex flex-col w-full">
    <Header />

    <main class="flex-1 doodle-paper py-16 md:py-24">
      <div class="max-w-3xl mx-auto px-4 md:px-6 text-center">
        <h1
          class="text-4xl md:text-5xl font-extrabold mb-8 font-heading text-(--text-primary)"
        >
          <span class="doodle-underline">Credits</span>
        </h1>

        <div class="py-20">
          <p class="text-(--text-tertiary) italic">
            (Intentionally left blank for future acknowledgments)
          </p>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
