---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllTools, getToolBySlug, getRelatedTools, getToolStatus } from "@/tools/_registry";
import { CATEGORY_INFO, STATUS_INFO } from "@/tools/_types";
import { ToolWrapper } from "@/components/advanced/ToolWrapper";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";

// Generate static paths for all tools
export function getStaticPaths() {
  const tools = getAllTools();
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const categoryInfo = CATEGORY_INFO[tool.category];
const relatedTools = getRelatedTools(tool);
const status = getToolStatus(tool);

// Structured Data: WebApplication
const structuredData: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": tool.schemaType ?? "WebApplication",
  name: tool.name,
  description: tool.description,
  url: Astro.url.href,
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};

// FAQ structured data
if (tool.faq?.length) {
  structuredData["mainEntity"] = tool.faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  }));
}
---

<BaseLayout
  title={tool.name}
  description={tool.description}
  ogImage={tool.ogImage}
  structuredData={structuredData}
>
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <Header activeTab="tools" />

    <main class="flex-1">
      <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 py-8 md:py-12">
        <!-- Breadcrumb -->
        <nav class="mb-6 text-sm" aria-label="Breadcrumb">
          <ol class="flex items-center gap-2 text-(--text-tertiary)">
            <li>
              <a href="/" class="hover:text(--text-primary) transition-colors"
                >Home</a
              >
            </li>
            <li>/</li>
            <li>
              <a
                href={`/#category-${tool.category}`}
                class="hover:text(--text-primary) transition-colors"
                >{categoryInfo.label}</a
              >
            </li>
            <li>/</li>
            <li class="text(--text-primary) font-medium">
              {tool.name}
            </li>
          </ol>
        </nav>

        <!-- Tool Header -->
        <div class="mb-8 flex items-center justify-between gap-8">
          <!-- LEFT CONTENT -->
          <div class="max-w-2xl flex flex-col gap-4">
            <div class="flex items-center flex-wrap gap-3">
              <h1
                class="text-3xl md:text-4xl font-bold text(--font-heading) doodle-underline"
              >
                {tool.name}
              </h1>

              {
                status && (
                  <div class="flex items-center gap-1.5 text-xs uppercase font-bold tracking-wider px-2.5 py-1 rounded-full bg-(--surface-secondary) text(--text-secondary) border border-(--border-default)">
                    <span class="font-emoji">
                      {STATUS_INFO[status].icon}
                    </span>
                    {STATUS_INFO[status].label}
                  </div>
                )
              }
            </div>

            <p class="text(--text-secondary) text-lg">
              {tool.longDescription ?? tool.description}
            </p>

            {
              tool.tags && (
                <div class="flex flex-wrap gap-2">
                  {tool.tags.map((tag) => (
                    <span class="px-2 py-0.5 text-xs rounded-full bg-(--surface-secondary) text(--text-secondary) border border-(--border-default)">
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }
          </div>

          <!-- RIGHT ICON -->
          <div class="text-8xl md:text-9xl opacity-80 font-emoji">
            {tool.icon}
          </div>
        </div>

        <!-- Tool Component (React Island) -->
        <section class="mb-12">
          <ToolWrapper tool={tool} client:idle />
        </section>

        <!-- How It Works -->
        {
          tool.howItWorks && (
            <section class="mb-12">
              <h2 class="text-xl font-semibold mb-6 text(--font-heading)">
                <span class="font-emoji">⚙️</span> How It Works
              </h2>
              <p class="text(--text-secondary) leading-relaxed mt-2">
                {tool.howItWorks}
              </p>
            </section>
          )
        }

        <!-- FAQ -->
        {
          tool.faq && tool.faq.length > 0 && (
            <section>
              <h2 class="text-xl font-semibold mb-12 text(--font-heading)">
                <span class="font-emoji">❓</span> Frequently Asked Questions
              </h2>
              <div class="mt-2 space-y-2">
                {tool.faq.map((item) => (
                  <details class="group border border-(--border-default) rounded-lg overflow-hidden">
                    <summary class="flex items-center justify-between cursor-pointer p-4 text(--text-primary) font-medium hover:bg-(--surface-secondary) transition-colors">
                      {item.question}
                      <span class="text-(--text-tertiary) group-open:rotate-180 transition-transform">
                        ▾
                      </span>
                    </summary>
                    <div class="px-4 pb-4 text-sm text(--text-secondary) leading-relaxed">
                      {item.answer}
                    </div>
                  </details>
                ))}
              </div>
            </section>
          )
        }

        <!-- Related Tools -->
        {
          relatedTools.length > 0 && (
            <section class="mb-12">
              <hr class="doodle-divider" />
              <h2
                class="text-xl font-semibold mb-4 text(--text-primary)"
                style="font-family: var(--font-heading)"
              >
                Related Tools
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {relatedTools.map((related) => (
                  <a
                    href={`/tools/${related.slug}`}
                    class="group block p-4 rounded-lg bg-(--surface-elevated) border border-(--border-default) no-underline transition-all duration-150 hover:border-(--border-hover) hover:shadow-md"
                  >
                    <div class="flex items-start gap-3">
                      <span class="text-xl font-emoji">{related.icon}</span>
                      <div>
                        <h3 class="text-sm font-semibold text(--text-primary)">
                          {related.name}
                        </h3>
                        <p class="text-xs text(--text-secondary) mt-1">
                          {related.description}
                        </p>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </div>
    </main>

    <!-- Footer -->
    <Footer />
  </div>
</BaseLayout>
