---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllTools,
  getToolBySlug,
  getRelatedTools,
  getToolStatus,
  getCategoryMeta,
} from "@/tools/_registry";
import { CATEGORY_INFO, STATUS_INFO } from "@/tools/_types";
import { ToolWrapper } from "@/components/advanced/ToolWrapper";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import Accordion from "@/components/ui/Accordion.astro";

// Generate static paths: /tools/:category/:slug
export function getStaticPaths() {
  const tools = getAllTools();
  return tools.map((tool) => ({
    params: { category: tool.category, slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const categoryInfo = getCategoryMeta(tool.category);
const relatedTools = getRelatedTools(tool);
const status = getToolStatus(tool);

// Inject offline capability FAQ if applicable
const toolFaq = [...(tool.faq || [])];
if (tool.capabilities?.supportsOffline) {
  toolFaq.push({
    question: `Does the ${tool.name} work offline?`,
    answer: `Yes, the ${tool.name} is fully functional offline. Because this tool runs entirely in your browser, no data is ever uploaded to external servers. Once the page is loaded, you can seamlessly continue using it without an active internet connection. You can also install Knicknaks as a Progressive Web App (PWA) for native-like offline access.`,
  });
}

// Structured Data: WebApplication
const structuredData: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": tool.schemaType ?? "WebApplication",
  name: tool.name,
  description: tool.description,
  url: Astro.url.href,
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};

// FAQ structured data
if (toolFaq.length > 0) {
  structuredData["mainEntity"] = toolFaq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  }));
}

// Build license sentence parts
function buildLicenseSentence(license: typeof tool.license) {
  if (!license) return null;
  const parts: string[] = [];
  let sentence = "This tool uses ";

  if (license.isModified) {
    sentence += "a modified version of ";
  }

  if (license.originalProjectName) {
    sentence = ""; // rebuild below
  }

  return license;
}
---

<BaseLayout
  title={tool.name}
  description={tool.description}
  ogImage={tool.ogImage}
  structuredData={structuredData}
>
  <div class="min-h-screen flex flex-col">
    <Header activeTab="tools" />

    <main class="flex-1">
      <div class="max-w-5xl mx-auto px-4 md:px-6 lg:px-8 py-8 md:py-12">
        <!-- Breadcrumb -->
        <nav class="mb-6 text-sm" aria-label="Breadcrumb">
          <ol
            class="flex items-center gap-2"
            style="color: var(--text-tertiary)"
          >
            <li>
              <a
                href="/"
                class="hover:opacity-80 transition-opacity"
                style="color: var(--text-tertiary)">Home</a
              >
            </li>
            <li>/</li>
            <li>
              <a
                href={`/tools/${tool.category}`}
                class="hover:opacity-80 transition-opacity"
                style="color: var(--text-tertiary)">{categoryInfo.label}</a
              >
            </li>
            <li>/</li>
            <li style="color: var(--text-primary)" class="font-medium">
              {tool.name}
            </li>
          </ol>
        </nav>

        <!-- Tool Header -->
        <div class="mb-8 flex items-center justify-between gap-8">
          <!-- LEFT CONTENT -->
          <div class="max-w-2xl flex flex-col gap-4">
            <div class="flex items-center flex-wrap gap-3">
              <h1
                class="text-3xl md:text-4xl font-bold doodle-underline"
                style="font-family: var(--font-heading); color: var(--text-primary)"
              >
                {tool.name}
              </h1>

              {
                status && (
                  <div
                    class="flex items-center gap-1.5 text-xs uppercase font-bold tracking-wider px-2.5 py-1 rounded-full border"
                    style="background: var(--surface-secondary); color: var(--text-secondary); border-color: var(--border-default)"
                  >
                    <span class="font-emoji">{STATUS_INFO[status].icon}</span>
                    {STATUS_INFO[status].label}
                  </div>
                )
              }
            </div>

            <p style="color: var(--text-secondary)" class="text-lg">
              {tool.description}
            </p>

            {
              tool.tags && (
                <div class="flex flex-wrap gap-2">
                  {tool.tags.map((tag) => (
                    <span
                      class="px-2 py-0.5 text-xs rounded-full border"
                      style="background: var(--surface-secondary); color: var(--text-secondary); border-color: var(--border-default)"
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              )
            }
          </div>

          <!-- RIGHT ICON -->
          <div class="text-8xl md:text-9xl opacity-80 font-emoji">
            {tool.icon}
          </div>
        </div>

        <!-- Tool Component (React Island) -->
        <section class="mb-12">
          <ToolWrapper tool={tool} client:idle />
        </section>

        <!-- License Attribution -->
        {
          tool.license && (
            <div
              class="text-sm mt-6 opacity-80"
              style="color: var(--text-secondary)"
            >
              <p>
                {tool.license.isModified
                  ? "This tool uses a modified version of "
                  : "This tool uses "}
                {tool.license.originalProjectName &&
                tool.license.originalProjectUrl ? (
                  <>
                    <a
                      href={tool.license.originalProjectUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-semibold underline"
                      style="color: var(--text-primary)"
                    >
                      <em>{tool.license.originalProjectName}</em>
                    </a>
                  </>
                ) : tool.license.originalProjectName ? (
                  <em class="font-semibold">
                    {tool.license.originalProjectName}
                  </em>
                ) : null}
                {tool.license.originalAuthor && (
                  <>
                    {" "}
                    by <strong>{tool.license.originalAuthor}</strong>
                  </>
                )}
                {(tool.license.originalProjectName ||
                  tool.license.originalAuthor) &&
                  " "}
                {tool.license.originalProjectName || tool.license.originalAuthor
                  ? "licensed under "
                  : "Licensed under "}
                <a
                  href={tool.license.licenseUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-semibold underline"
                  style="color: var(--text-primary)"
                >
                  {tool.license.licenseName}
                </a>
                .{" "}
                <a
                  href={tool.license.licenseUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="underline"
                  style="color: var(--text-tertiary)"
                >
                  View license
                </a>
                .
              </p>
            </div>
          )
        }

        <!-- How It Works -->
        {
          tool.howItWorks && (
            <section class="mb-12">
              <h2
                class="text-xl font-semibold mb-6"
                style="font-family: var(--font-heading); color: var(--text-primary)"
              >
                <span class="font-emoji">⚙️</span> How It Works
              </h2>
              <p
                class="leading-relaxed mt-2"
                style="color: var(--text-secondary)"
              >
                {tool.howItWorks}
              </p>
            </section>
          )
        }

        <!-- FAQ -->
        {
          toolFaq.length > 0 && (
            <section>
              <h2
                class="text-xl font-semibold mb-12"
                style="font-family: var(--font-heading); color: var(--text-primary)"
              >
                <span class="font-emoji">❓</span> Frequently Asked Questions
              </h2>
              <div class="mt-2 space-y-2">
                {toolFaq.map((item) => (
                  <Accordion label={item.question} content={item.answer} />
                ))}
              </div>
            </section>
          )
        }

        <!-- Related Tools -->
        {
          relatedTools.length > 0 && (
            <section class="mb-12">
              <hr class="doodle-divider" />
              <h2
                class="text-xl font-semibold mb-4"
                style="font-family: var(--font-heading); color: var(--text-primary)"
              >
                Related Tools
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {relatedTools.map((related) => (
                  <a
                    href={`/tools/${related.category}/${related.slug}`}
                    class="group block p-4 rounded-lg border no-underline transition-[border-color,box-shadow] duration-150"
                    style="background: var(--surface-elevated); border-color: var(--border-default)"
                  >
                    <div class="flex items-start gap-3">
                      <span class="text-xl font-emoji">{related.icon}</span>
                      <div>
                        <h3
                          class="text-sm font-semibold"
                          style="color: var(--text-primary)"
                        >
                          {related.name}
                        </h3>
                        <p
                          class="text-xs mt-1"
                          style="color: var(--text-secondary)"
                        >
                          {related.description}
                        </p>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>

<!-- Recently Used: push current tool into localStorage -->
<script define:vars={{ toolData: { slug: tool.slug, name: tool.name, description: tool.description, icon: tool.icon, category: tool.category } }}>
  (function () {
    const STORAGE_KEY = "knicknaks_recent_tools";
    const MAX_ITEMS = 4;

    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      let recent = stored ? JSON.parse(stored) : [];

      // Remove duplicate if this tool already exists
      recent = recent.filter((t) => t.slug !== toolData.slug);

      // Push current tool to the front
      recent.unshift(toolData);

      // Keep only the last MAX_ITEMS
      if (recent.length > MAX_ITEMS) {
        recent = recent.slice(0, MAX_ITEMS);
      }

      localStorage.setItem(STORAGE_KEY, JSON.stringify(recent));
    } catch (e) {
      // Silently fail if localStorage is unavailable
    }
  })();
</script>
