---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getToolsByCategory,
  getActiveCategories,
  getCategoryMeta,
  getToolStatus,
} from "@/tools/_registry";
import {
  TOOL_STATUSES,
  STATUS_INFO,
  CATEGORY_INFO,
  type ToolCategory,
} from "@/tools/_types";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import ToolCard from "@/components/advanced/ToolCard.astro";

export function getStaticPaths() {
  const categories = getActiveCategories();
  return categories.map((category) => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props as { category: ToolCategory };
const info = getCategoryMeta(category);
const categoryTools = getToolsByCategory(category);

// Collect ALL tool emojis
const allToolEmojis = categoryTools.map((t) => t.icon);

// Build the mosaic emoji list by reusing only tool emojis

const TARGET = 96;
let mosaicEmojis = [...allToolEmojis];

// Re-use tool emojis (cycling) until we hit the target
let toolIdx = 0;
while (mosaicEmojis.length < TARGET && allToolEmojis.length > 0) {
  mosaicEmojis.push(allToolEmojis[toolIdx % allToolEmojis.length]);
  toolIdx++;
}

// Shuffle the array for a more organic feel
// (deterministic pseudo-shuffle based on index so SSR is stable)
function mulberry32(a: number) {
  return function () {
    let t = (a += 0x6d2b79f5);
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(Math.floor(Math.random() * 90000) + 10000);

const shuffled = [...mosaicEmojis].sort(() => rand() - 0.5);

const pageTitle = info.seoTitle || `${info.label} — Knicknaks`;
const pageDescription = info.seoDescription || info.description;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={info.ogImage}
>
  <div class="min-h-screen flex flex-col">
    <Header activeTab="tools" />

    <main class="flex-1">
      <!-- Hero Section -->
      <section class="hero-section py-16 md:py-24 relative overflow-hidden">
        <!-- Packed emoji mosaic background -->
        <div class="emoji-mosaic" aria-hidden="true">
          {
            shuffled.map((emoji, i) => {
              // Deterministic size variation: cycle through 5 size buckets
              const sizeClass = `emoji-sz-${(i * 3 + 7) % 5}`;
              // Deterministic rotation
              const rot = ((i * 137) % 41) - 20; // -20 to +20 degrees
              return (
                <span
                  class={`mosaic-emoji font-emoji ${sizeClass}`}
                  style={`--rot: ${rot}deg; animation-delay: ${(i % 20) * 0.04}s`}
                >
                  {emoji}
                </span>
              );
            })
          }
        </div>

        <!-- Overlay gradient so text stays readable -->
        <div class="hero-overlay" aria-hidden="true"></div>

        <!-- Centered hero content -->
        <div
          class="relative z-10 max-w-3xl mx-auto px-4 flex flex-col items-center justify-center text-center"
          style="min-height: 200px;"
        >
          <div class="text-5xl mb-4 font-emoji hero-icon">{info.icon}</div>
          <h1
            class="text-4xl md:text-5xl font-extrabold mb-3 hero-title doodle-underline"
            style="font-family: var(--font-heading);"
          >
            {info.label}
          </h1>
          {
            info.heroTagline && (
              <p class="text-lg font-semibold mb-2 hero-tagline">
                {info.heroTagline}
              </p>
            )
          }
          <p class="text-base md:text-lg max-w-xl mx-auto hero-desc">
            {info.heroDescription || info.description}
          </p>
        </div>
      </section>

      <hr class="doodle-divider max-w-full mx-auto" />

      <!-- Tool Grid -->
      <section class="pb-16 md:pb-24" id="tools">
        <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 pt-8">
          {
            categoryTools.length > 0 ? (
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                {categoryTools.map((tool) => (
                  <ToolCard tool={tool} />
                ))}
              </div>
            ) : (
              <div class="text-center py-16">
                <p class="text-4xl mb-4">🧰</p>
                <p style="color: var(--text-secondary)">
                  No tools in this category yet. Check back soon!
                </p>
              </div>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  /* ── Hero section ── */
  .hero-section {
    min-height: 340px;
    display: flex;
    align-items: center;
  }

  /* ── Emoji mosaic: absolute fill, flex-wrap packed ── */
  .emoji-mosaic {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    overflow: hidden;
    gap: 0;
  }

  .mosaic-emoji {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transform: rotate(var(--rot, 0deg));
    line-height: 1;
    margin: -2px;
    animation: emojiPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  /* Size variants */
  .emoji-sz-0 {
    font-size: 3.5rem;
    width: 3.8rem;
    height: 3.8rem;
  }
  .emoji-sz-1 {
    font-size: 5rem;
    width: 5.4rem;
    height: 5.4rem;
  }
  .emoji-sz-2 {
    font-size: 4rem;
    width: 4.4rem;
    height: 4.4rem;
  }
  .emoji-sz-3 {
    font-size: 6rem;
    width: 6.4rem;
    height: 6.4rem;
  }
  .emoji-sz-4 {
    font-size: 2.8rem;
    width: 3.2rem;
    height: 3.2rem;
  }

  @keyframes emojiPop {
    0% {
      opacity: 0;
      transform: rotate(var(--rot, 0deg)) scale(0.4);
    }
    70% {
      opacity: 0.9;
      transform: rotate(var(--rot, 0deg)) scale(1.1);
    }
    100% {
      opacity: 0.5;
      transform: rotate(var(--rot, 0deg)) scale(1);
    }
  }

  /* ── Overlay: radial gradient using CSS var so it respects dark mode ── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(
      ellipse 65% 85% at 50% 50%,
      var(--surface-bg) 25%,
      transparent 100%
    );
  }

  /* Text — no hardcoded white glow, use bg var for the shadow */
  .hero-title {
    color: var(--color-primary-500);
    text-shadow:
      0 2px 12px var(--surface-bg),
      0 0 24px var(--surface-bg);
  }

  .hero-tagline {
    text-shadow: 0 1px 8px var(--surface-bg);
  }

  .hero-desc {
    text-shadow: 0 1px 6px var(--surface-bg);
  }

  .hero-icon {
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.15));
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .mosaic-emoji {
      animation: none;
      opacity: 1;
    }
  }
</style>
