---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getToolsByCategory,
  getActiveCategories,
  getCategoryMeta,
  getToolStatus,
} from "@/tools/_registry";
import {
  TOOL_STATUSES,
  STATUS_INFO,
  CATEGORY_INFO,
  type ToolCategory,
  type ToolDefinition,
} from "@/tools/_types";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import ToolCard from "@/components/advanced/ToolCard.astro";
import type { ComponentType } from "react";

export function getStaticPaths() {
  const categories = getActiveCategories();
  return categories.map((category) => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props as { category: ToolCategory };
const info = getCategoryMeta(category);
const categoryTools = getToolsByCategory(category);

// Collect ALL tool emojis
const allToolEmojis = categoryTools.map((t) => t.icon);

// Build the mosaic emoji list by reusing only tool emojis

const TARGET = 96;
let mosaicEmojis = [...allToolEmojis];

// Re-use tool emojis (cycling) until we hit the target
let toolIdx = 0;
while (mosaicEmojis.length < TARGET && allToolEmojis.length > 0) {
  mosaicEmojis.push(allToolEmojis[toolIdx % allToolEmojis.length]);
  toolIdx++;
}

// Shuffle the array for a more organic feel
// (deterministic pseudo-shuffle based on index so SSR is stable)
function mulberry32(a: number) {
  return function () {
    let t = (a += 0x6d2b79f5);
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(Math.floor(Math.random() * 90000) + 10000);

const shuffled = [...mosaicEmojis].sort(() => rand() - 0.5);

const pageTitle = info.seoTitle || `${info.label} — Knicknaks`;
const pageDescription = info.seoDescription || info.description;

const home: ToolDefinition = {
  name: "Other tools",
  slug: "/",
  icon: "🌏",
  description: "View other tools from different categories",
  tags: [],
  category: "encoders",
  keywords: [],
  component: function (): Promise<{ default: ComponentType }> {
    throw new Error("Function not implemented.");
  },
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={info.ogImage}
>
  <div class="min-h-screen flex flex-col">
    <Header activeTab="tools" />

    <main class="flex-1">
      <!-- Hero Section -->
      <section
        class="doodle-hero min-h-[340px] flex align-center py-16 md:py-24 relative overflow-hidden"
        style="box-shadow: 0 30px 40px var(--surface-bg);
        mask: conic-gradient(from -32.5deg at bottom,#0000,#000 1deg 64deg,#0000 65deg) 50%/17.84px 100%
        "
      >
        <!-- <div
          aria-hidden="true"
          class="doodle-paper absolute inset-0 w-full h-full"
        >
        </div> -->

        <!-- Centered hero content -->
        <div
          class="max-w-3xl mx-auto px-4 flex flex-col items-center justify-center text-center gap-2"
        >
          <div class="text-5xl font-emoji hero-icon">{info.icon}</div>
          <h1
            class="text-4xl md:text-5xl font-extrabold doodle-underline text-primary-500"
            style="font-family: var(--font-heading);"
          >
            {info.label}
          </h1>
          <!-- {
            info.heroTagline && (
              <p class="text-lg font-semibold hero-tagline">
                {info.heroTagline}
              </p>
            )
          } -->
          <p class="text-base mt-8 md:text-lg max-w-xl mx-auto hero-desc">
            {info.heroDescription || info.description}
          </p>
        </div>
      </section>
      <!-- <hr class="doodle-divider max-w-full mx-auto" /> -->

      <!-- Tool Grid -->
      <section class="pb-16 md:pb-24" id="tools">
        <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 pt-8">
          {
            categoryTools.length > 0 ? (
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                {categoryTools.map((tool) => (
                  <ToolCard tool={tool} />
                ))}
                <ToolCard tool={home} homeCard={true} />
              </div>
            ) : (
              <div class="text-center py-16">
                <p class="text-4xl mb-4">🧰</p>
                <p style="color: var(--text-secondary)">
                  No tools in this category yet. Check back soon!
                </p>
                <ToolCard tool={home} homeCard={true} />
              </div>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  /* ── Hero section ── */
  .hero-section {
    min-height: 340px;
    display: flex;
    align-items: center;
  }

  .hero-tagline {
    text-shadow: 0 1px 8px var(--surface-bg);
  }

  .hero-desc {
    text-shadow: 0 1px 6px var(--surface-bg);
  }

  .hero-icon {
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.15));
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .mosaic-emoji {
      animation: none;
      opacity: 1;
    }

    .doodle-paper {
      animation: none;
    }
  }
</style>
