---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
---

<BaseLayout title="This page is lost" description="404 Page">
  <div class="min-h-screen flex flex-col w-full">
    <Header />

    <main class="flex-1 doodle-paper py-16 md:py-24">
      <div class="max-w-3xl mx-auto px-4 md:px-6 text-center">
        <span aria-hidden="true" class="font-emoji text-6xl">🐓</span>
        <span aria-hidden="true" class="font-emoji text-xl">🐤🐤🐤</span>
        <h1
          class="text-4xl md:text-5xl font-extrabold mb-8 font-heading text-(--text-primary) doodle-underline"
        >
          Nobody here but us chickens
        </h1>
        <p class="text-(--text-secondary) mt-4">
          The page you're looking for doesn't exist.
        </p>
        <div
          class="mt-10 flex flex-row flex-wrap gap-6 justify-center items-center"
        >
          <button
            onclick="if (history.length > 1) history.back(); else window.location.href='/'"
            class="px-6 py-3 rounded-lg cursor-pointer bg-(--surface-elevated) border border-(--border-default) text-primary-500 font-bold hover:border-primary-400 hover:shadow-md transition-all active:translate-y-0.5"
            ><span class="font-emoji pr-2">⬅</span>Go back
          </button>
          <span class="text-sm text-(--text-tertiary) uppercase">or</span>
          <a
            href="/"
            class="px-6 py-3 rounded-lg bg-(--surface-elevated) border border-(--border-default) font-bold hover:border-primary-400 hover:shadow-md transition-all active:translate-y-0.5"
            ><span class="font-emoji pr-2">🏡</span>Home
          </a>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
