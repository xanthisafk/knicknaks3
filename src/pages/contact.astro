---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { CopyButton } from "@/components/ui";

const email = "abhinav.ranger@gmail.com";
---

<BaseLayout
  title="Contact Us — Knicknaks"
  description="Get in touch with the creator of Knicknaks for feedback, bug reports, and suggestions."
>
  <div class="min-h-screen flex flex-col w-full">
    <Header />

    <main class="flex-1 doodle-paper py-16 md:py-24">
      <div class="max-w-3xl mx-auto px-4 md:px-6 text-center">
        <h1
          class="text-4xl md:text-5xl font-extrabold mb-8 font-heading text-(--text-primary)"
        >
          <span class="doodle-underline">Contact</span>
        </h1>

        <div class="py-20">
          <p class="text-(--text-primary)">
            Send an email to <a
              class="doodle-underline font-bold text-primary-500 hover:text-primary-400"
              href={"mailto:" + email}>{email}</a
            >
            <CopyButton client:load text={email} />
          </p>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
