---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllTools,
  getActiveCategories,
  getToolsByCategory,
  getFeaturedToolsForCategory,
  getCategoryMeta,
} from "@/tools/_registry";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import ToolCard from "@/components/advanced/ToolCard.astro";
import { ArrowDown, Download, Rose } from "lucide-react";
import { Button } from "@/components/ui";

const allTools = getAllTools();
const activeCategories = getActiveCategories();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Knicknaks",
  description: "Free, offline-capable web app with useful day-to-day tools.",
  url: Astro.site?.toString(),
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};

const toolCount = allTools.length;
const formatted =
  toolCount % 5 === 0
    ? toolCount.toString()
    : `${toolCount - (toolCount % 5)}+`;
---

<BaseLayout title="Knicknaks" structuredData={structuredData}>
  <div class="min-h-screen flex flex-col">
    <Header activeTab="tools" />

    <main class="flex-1">
      <section class="py-16 md:py-24 text-center relative">
        <div class="relative z-10 max-w-3xl mx-auto px-4">
          <h1
            class="text-4xl md:text-6xl font-extrabold mb-4"
            style="font-family: var(--font-heading); color: var(--text-primary)"
          >
            Your go-to <span class="doodle-underline text-primary-500"
              >Toolbox</span
            >
          </h1>
          <p
            class="text-lg md:text-xl my-8 max-w-xl mx-auto"
            style="color: var(--text-secondary)"
          >
            {formatted} free, fast, and privacy-friendly tools that run entirely in
            your browser. No signup. No tracking. No nonsense.
          </p>

          <!-- Search Trigger -->
          <div class="relative max-w-md mx-auto mb-6">
            <button
              type="button"
              onclick="window.dispatchEvent(new CustomEvent('open-command-palette'))"
              class="w-full text-left px-4 py-3 pl-10 rounded-xl border text-base cursor-pointer transition-colors"
              style="background: var(--surface-elevated); color: var(--text-tertiary); border-color: var(--border-default)"
            >
              Search for a tool, description or tag...
            </button>
            <span
              class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none font-emoji"
              style="color: var(--text-tertiary)">🔍</span
            >
            <div
              class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none"
            >
              <span
                id="search-hint"
                class="hidden sm:block text-xs font-bold px-2 py-1 border rounded-md"
                style="color: var(--text-tertiary); border-color: var(--border-default); background: var(--surface-bg)"
                >⌘K</span
              >
            </div>
          </div>

          <div
            class=`
            pwa-install-btn flex items-center justify-center gap-6 text-2xl font-bold hover:text-primary-500
            cursor-pointer p-3 rounded-lg mx-auto
            `
            style={{ opacity: "0" }}
            role="button"
            tabindex="0"
          >
            <Download size={32} />
            <span class="font-heading doodle-underline">Install App</span>
          </div>

          <a
            href="#tools"
            class="cursor-pointer group mx-auto"
            role="button"
            tabindex="0"
          >
            <div
              class=`
              mt-20 flex gap-2 flex-row items-center justify-center group-focus:ring-2
              group-focus:ring-primary-500 p-3 rounded-lg
              `
            >
              <ArrowDown
                className="animate-bounce text-primary-500 translate-y-1"
              />
              <p class="font-heading uppercase text-(--text-tertiary)">
                View tools
              </p>
            </div>
          </a>
        </div>
      </section>
    </main>

    <hr class="doodle-divider max-w-full mx-auto" />

    <!-- Category Previews -->
    <section class="pb-16 md:pb-24 scroll-mt-20" id="tools">
      <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
        <!-- Recently Used (client-side populated) -->
        <div
          id="recently-used-section"
          class="mb-12 category-section"
          style="display:none;"
        >
          <div class="mb-6">
            <div
              class="text-2xl font-bold flex items-center gap-2"
              style="font-family: var(--font-heading); color: var(--text-primary)"
            >
              <span class="font-emoji">🕐</span>
              Recently Used
            </div>
            <p class="text-sm mt-1" style="color: var(--text-secondary)">
              Tools you've used recently — jump back in
            </p>
          </div>
          <div
            id="recently-used-grid"
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"
          >
          </div>
        </div>

        {
          activeCategories.length > 0 ? (
            activeCategories.map((category) => {
              const info = getCategoryMeta(category);
              const previewTools = getFeaturedToolsForCategory(category, 3);
              const allCatTools = getToolsByCategory(category);
              const totalCount = allCatTools.length;
              return (
                <div
                  class="mb-12 category-section"
                  id={`category-${category}`}
                  data-category={category}
                >
                  <div class="mb-6">
                    <a
                      href={`/tools/${category}`}
                      class="text-2xl font-bold flex items-center gap-2 no-underline hover:opacity-80 transition-opacity"
                      style={`font-family: var(--font-heading); color: var(--text-primary)`}
                    >
                      <span class="font-emoji">{info.icon}</span>
                      {info.label}
                      <span
                        class="text-sm font-normal"
                        style="color: var(--text-tertiary)"
                      >
                        →
                      </span>
                    </a>
                    <p
                      class="text-sm mt-1"
                      style="color: var(--text-secondary)"
                    >
                      {info.description}
                    </p>
                  </div>
                  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                    {previewTools.map((tool) => (
                      <ToolCard tool={tool} previewOnly={true} />
                    ))}
                    {/* "View all" card */}
                    {totalCount > 3 && (
                      <a
                        href={`/tools/${category}`}
                        class="group flex flex-col items-center justify-center p-5 rounded-lg border border-dashed no-underline transition-colors"
                        style="border-color: var(--border-default); color: var(--text-secondary); background: var(--surface-bg)"
                      >
                        <span class="text-3xl mb-2 font-emoji">
                          {info.icon}
                        </span>
                        <span
                          class="font-semibold text-sm"
                          style="color: var(--text-primary)"
                        >
                          View all {totalCount} tools →
                        </span>
                      </a>
                    )}
                  </div>
                </div>
              );
            })
          ) : (
            <div class="text-center py-16">
              <p class="text-4xl mb-4">🧰</p>
              <p style="color: var(--text-secondary)">
                Tools are being crafted. Check back soon!
              </p>
            </div>
          )
        }
      </div>
    </section>
  </div>

  <Footer />
</BaseLayout>

<!-- Search hint: platform detection -->
<script>
  const hint = document.getElementById("search-hint");
  if (hint) {
    hint.textContent = /Mac|iPhone|iPad|iPod/i.test(navigator.userAgent)
      ? "⌘K"
      : "Ctrl+K";
  }
</script>

<!-- Recently Used: retrieve from localStorage and render -->
<script>
  (function () {
    const STORAGE_KEY = "knicknaks_recent_tools";
    const section = document.getElementById("recently-used-section");
    const grid = document.getElementById("recently-used-grid");
    if (!section || !grid) return;

    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (!stored) return;

      const recent = JSON.parse(stored);
      if (!Array.isArray(recent) || recent.length === 0) return;

      recent.forEach((tool) => {
        const card = document.createElement("a");
        card.href = `/tools/${tool.category}/${tool.slug}`;
        card.className =
          "group flex flex-col p-4 md:p-5 rounded-lg border no-underline transition-[transform,border-color,box-shadow] duration-150 tool-card relative overflow-visible hover:shadow-md";
        card.style.cssText =
          "background: var(--surface-elevated); border-color: var(--border-default)";
        card.dataset.toolSlug = tool.slug;

        card.innerHTML = `
          <div class="flex items-start gap-3 flex-1 group">
            <span class="text-2xl shrink-0 mt-0.5 font-emoji">${escapeHtml(tool.icon)}</span>
            <div>
              <span class="font-emoji text-6xl absolute right-0 opacity-0
                translate-x-[25px] rotate-12
                transition-[transform,opacity] duration-300
                group-hover:translate-x-[-10px] group-hover:opacity-30 group-hover:-rotate-12">${escapeHtml(tool.icon)}</span>
              <h3 class="text-sm font-semibold group-hover:text-primary-600"
                  style="font-family: var(--font-heading); color: var(--text-primary)">
                ${escapeHtml(tool.name)}
              </h3>
              <p class="text-xs mt-1 line-clamp-2" style="color: var(--text-secondary)">
                ${escapeHtml(tool.description)}
              </p>
            </div>
          </div>`;

        grid.appendChild(card);
      });

      section.style.display = "";
    } catch (e) {
      // Silently fail
    }

    function escapeHtml(str: string) {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    }
  })();
</script>
