---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllTools,
  getToolsByCategory,
  getActiveCategories,
} from "@/tools/_registry";
import { CATEGORY_INFO, TOOL_STATUSES, STATUS_INFO } from "@/tools/_types";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import ToolCard from "@/components/advanced/ToolCard.astro";

const allTools = getAllTools();
const activeCategories = getActiveCategories();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Knicknaks",
  description: "Free, offline-capable web app with useful day-to-day tools.",
  url: Astro.site?.toString(),
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---

<BaseLayout title="Knicknaks" structuredData={structuredData}>
  <div class="min-h-screen flex flex-col">
    <Header activeTab="tools" />

    <main class="flex-1">
      <section class="py-16 md:py-24 text-center relative">
        <div class="relative z-10 max-w-3xl mx-auto px-4">
          <h1
            class="text-4xl md:text-6xl font-extrabold mb-4"
            style="font-family: var(--font-heading); color: var(--text-primary)"
          >
            Your go-to <span class="doodle-underline text-primary-500"
              >Toolbox</span
            >
          </h1>
          <p
            class="text-lg md:text-xl my-8 max-w-xl mx-auto"
            style="color: var(--text-secondary)"
          >
            Free, fast, and privacy-friendly tools that run entirely in your
            browser. No signup. No tracking. No nonsense.
          </p>

          <!-- Search Trigger -->
          <div class="relative max-w-md mx-auto mb-6">
            <button
              type="button"
              onclick="window.dispatchEvent(new CustomEvent('open-command-palette'))"
              class="w-full text-left px-4 py-3 pl-10 rounded-xl border text-base cursor-pointer transition-colors"
              style="background: var(--surface-elevated); color: var(--text-tertiary); border-color: var(--border-default)"
            >
              Search for a tool, description or tag...
            </button>
            <span
              class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none font-emoji"
              style="color: var(--text-tertiary)">🔍</span
            >
            <div
              class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none"
            >
              <span
                id="search-hint"
                class="hidden sm:block text-xs font-bold px-2 py-1 border rounded-md"
                style="color: var(--text-tertiary); border-color: var(--border-default); background: var(--surface-bg)"
                >⌘K</span
              >
            </div>
          </div>

          <!-- Status Filters — plain pills, no animation baked in -->
          <div
            class="flex flex-wrap items-center justify-center gap-1 max-w-2xl mx-auto"
            id="status-filter-group"
          >
            <button
              class="status-filter-btn px-3 py-1 rounded-full text-xs font-medium cursor-pointer transition-colors"
              data-status="all"
              data-active="true"
            >
              <span class="mr-1 font-emoji">🌏</span>All Tools
            </button>
            {
              TOOL_STATUSES.map((status) => {
                const info = STATUS_INFO[status];
                return (
                  <button
                    class="status-filter-btn px-3 py-1 rounded-full text-xs font-medium cursor-pointer transition-colors"
                    data-status={status}
                  >
                    <span class="mr-1 font-emoji">{info.icon}</span>
                    {info.label}
                  </button>
                );
              })
            }
          </div>
        </div>
      </section>

      <hr class="doodle-divider max-w-full mx-auto" />

      <!-- Tool Grid -->
      <section class="pb-16 md:pb-24" id="tools">
        <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
          {
            activeCategories.length > 0 ? (
              activeCategories.map((category) => {
                const categoryTools = getToolsByCategory(category);
                const info = CATEGORY_INFO[category];
                return (
                  <div
                    class="mb-12 category-section"
                    id={`category-${category}`}
                    data-category={category}
                  >
                    <div class="mb-6">
                      <h2
                        class="text-2xl font-bold flex items-center gap-2"
                        style="font-family: var(--font-heading); color: var(--text-primary)"
                      >
                        <span class="font-emoji">{info.icon}</span>
                        {info.label}
                      </h2>
                      <p
                        class="text-sm mt-1"
                        style="color: var(--text-secondary)"
                      >
                        {info.description}
                      </p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                      {categoryTools.map((tool) => (
                        <ToolCard tool={tool} />
                      ))}
                    </div>
                  </div>
                );
              })
            ) : (
              <div class="text-center py-16">
                <p class="text-4xl mb-4">🧰</p>
                <p style="color: var(--text-secondary)">
                  Tools are being crafted. Check back soon!
                </p>
              </div>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<!-- Search hint: platform detection -->
<script>
  const hint = document.getElementById("search-hint");
  if (hint) {
    hint.textContent = /Mac|iPhone|iPad|iPod/i.test(navigator.userAgent)
      ? "⌘K"
      : "Ctrl+K";
  }
</script>

<!-- Status filter -->
<script>
  function applyActiveStyle(btn: HTMLButtonElement, active: boolean) {
    if (active) {
      btn.style.background = "var(--surface-elevated)";
      btn.style.color = "var(--text-primary)";
      btn.setAttribute("data-active", "true");
    } else {
      btn.style.background = "transparent";
      btn.style.color = "var(--text-secondary)";
      btn.removeAttribute("data-active");
    }
  }

  function initFilter() {
    const filterBtns =
      document.querySelectorAll<HTMLButtonElement>(".status-filter-btn");
    const toolCards = document.querySelectorAll<HTMLElement>(".tool-card");
    const categorySections =
      document.querySelectorAll<HTMLElement>(".category-section");
    const toolsContainer = document.getElementById("tools");

    let activeStatus = "all";
    let noResultsMsg: HTMLElement | null = null;

    // Apply initial active style
    filterBtns.forEach((btn) => {
      applyActiveStyle(btn, btn.dataset.status === "all");
    });

    function runFilter() {
      // Filter cards
      toolCards.forEach((card) => {
        const matches =
          activeStatus === "all" || card.dataset.toolStatus === activeStatus;
        card.hidden = !matches;
      });

      // Hide/show categories based on visible children
      let anyVisible = false;
      categorySections.forEach((section) => {
        const hasVisible =
          activeStatus === "all" ||
          Array.from(section.querySelectorAll<HTMLElement>(".tool-card")).some(
            (c) => !c.hidden,
          );
        section.hidden = !hasVisible;
        if (hasVisible) anyVisible = true;
      });

      // No-results message
      if (!anyVisible && activeStatus !== "all") {
        if (!noResultsMsg) {
          noResultsMsg = document.createElement("div");
          noResultsMsg.id = "no-results-msg";
          noResultsMsg.className = "text-center py-16 w-full";
          noResultsMsg.innerHTML = `
            <p class="text-4xl mb-4">🔍</p>
            <p style="color:var(--text-primary)" class="font-semibold">No tools found</p>
            <p style="color:var(--text-secondary)" class="mt-2">Try a different filter.</p>
          `;
          toolsContainer?.appendChild(noResultsMsg);
        }
        noResultsMsg.hidden = false;
      } else if (noResultsMsg) {
        noResultsMsg.hidden = true;
      }
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeStatus = btn.dataset.status ?? "all";
        filterBtns.forEach((b) => applyActiveStyle(b, b === btn));
        runFilter();
      });
    });
  }

  document.addEventListener("astro:page-load", initFilter);
  initFilter();
</script>
