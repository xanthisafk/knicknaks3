---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllTools,
  getToolsByCategory,
  getActiveCategories,
} from "@/tools/_registry";
import { CATEGORY_INFO, TOOL_STATUSES, STATUS_INFO } from "@/tools/_types";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import ToolCard from "@/components/advanced/ToolCard.astro";

const allTools = getAllTools();
const activeCategories = getActiveCategories();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Knicknaks",
  description: "Free, offline-capable web app with useful day-to-day tools.",
  url: Astro.site?.toString(),
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};
---

<BaseLayout title="Knicknaks" structuredData={structuredData}>
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <Header activeTab="tools" />

    <main class="flex-1 doodle-paper">
      <!-- Hero Section -->
      <section class="py-16 md:py-24 text-center">
        <div class="max-w-3xl mx-auto px-4">
          <h1
            class="text-4xl md:text-6xl font-extrabold mb-4 text(--text-primary)"
            style="font-family: var(--font-heading)"
          >
            Your go-to <span class="doodle-underline text-primary-500"
              >Toolbox</span
            >
          </h1>
          <p
            class="text-lg md:text-xl text(--text-secondary) my-8 max-w-xl mx-auto"
          >
            Free, fast, and privacy-friendly tools that run entirely in your
            browser. No signup. No tracking. No nonsense.
          </p>

          <!-- Search -->
          <div class="relative max-w-md mx-auto mb-6">
            <input
              id="tool-search"
              type="search"
              placeholder="Search for a tool, description or tag..."
              autocomplete="off"
              class="w-full px-4 py-3 pl-10 rounded-xl bg-(--surface-elevated) text(--text-primary) border border-(--border-default) placeholder:text-(--text-tertiary) shadow-sm focus:outline-none focus:border-(--border-focus) focus:ring-2 focus:ring-(--ring-color) text-base"
            />
            <span
              class="absolute left-3 top-1/2 -translate-y-1/2 text-(--text-tertiary) font-emoji"
              >🔍</span
            >
            <div
              class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none"
            >
              <span
                class="hidden sm:block text-xs font-bold text-(--text-tertiary) px-2 py-1 border border-(--border-default) rounded-md bg-(--surface-bg)"
                id="search-hint"
              >
                ⌘K
              </span>
            </div>
          </div>

          <!-- Status Filters -->
          <div
            class="relative flex flex-wrap items-center justify-center gap-1 max-w-2xl mx-auto"
            id="status-filter-group"
          >
            {/* Sliding pill — positioned absolutely, moved via JS */}
            <div
              id="filter-pill"
              class="absolute rounded-full bg-white/10 backdrop-blur-sm transition-[left,top,width,height] duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] pointer-events-none"
              aria-hidden="true"
            >
            </div>

            <button
              class="status-filter-btn relative z-10 px-2 py-1 rounded-full text-xs font-medium cursor-pointer text-(--text-primary)"
              data-status="all"
            >
              <span class="mr-1 font-emoji">🌏</span>All Tools
            </button>

            {
              TOOL_STATUSES.map((status) => {
                const info = STATUS_INFO[status];
                return (
                  <button
                    class="status-filter-btn relative z-10 px-2 py-1 rounded-full text-xs font-medium cursor-pointer text-(--text-secondary)  "
                    data-status={status}
                  >
                    <span class="mr-1 font-emoji">{info.icon}</span>
                    {info.label}
                  </button>
                );
              })
            }
          </div>
        </div>
      </section>

      <hr class="doodle-divider max-w-full mx-auto" />

      <!-- Tool Grid -->
      <section class="pb-16 md:pb-24" id="tools">
        <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
          {
            activeCategories.length > 0 ? (
              activeCategories.map((category) => {
                const categoryTools = getToolsByCategory(category);
                const info = CATEGORY_INFO[category];
                return (
                  <div
                    class="mb-12 category-section"
                    id={`category-${category}`}
                    data-category={category}
                  >
                    <div class="mb-6">
                      <h2
                        class="text-2xl font-bold text(--text-primary) flex items-center gap-2"
                        style="font-family: var(--font-heading)"
                      >
                        <span class="font-emoji">{info.icon}</span>
                        {info.label}
                      </h2>
                      <p class="text-sm text(--text-secondary) mt-1">
                        {info.description}
                      </p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                      {categoryTools.map((tool) => (
                        <ToolCard tool={tool} />
                      ))}
                    </div>
                  </div>
                );
              })
            ) : (
              <div class="text-center py-16">
                <p class="text-4xl mb-4">🧰</p>
                <p class="text(--text-secondary)">
                  Tools are being crafted. Check back soon!
                </p>
              </div>
            )
          }
        </div>
      </section>
    </main>

    <!-- Footer -->
    <Footer />
  </div>

  <script>
    import { searchTools } from "@/lib/search";
    import { debounce } from "@/lib/utils";

    const searchInput = document.getElementById(
      "tool-search",
    ) as HTMLInputElement;
    const toolCards = document.querySelectorAll(
      ".tool-card",
    ) as NodeListOf<HTMLElement>;
    const categorySections = document.querySelectorAll(
      ".category-section",
    ) as NodeListOf<HTMLElement>;
    const toolsContainer = document.getElementById("tools");
    const filterBtns = document.querySelectorAll(
      ".status-filter-btn",
    ) as NodeListOf<HTMLButtonElement>;

    let activeStatus = "all";

    const handleSearch = debounce(() => {
      const query = searchInput ? searchInput.value : "";
      const results = query.trim() !== "" ? searchTools(query) : [];
      const resultSlugs = new Set(results.map((t) => t.slug));

      // Show/hide tools
      toolCards.forEach((card) => {
        const slug = card.getAttribute("data-tool-slug");
        const status = card.getAttribute("data-tool-status");

        const matchesSearch =
          query.trim() === "" || (slug && resultSlugs.has(slug));
        const matchesStatus = activeStatus === "all" || status === activeStatus;

        if (matchesSearch && matchesStatus) {
          card.style.display = "block";
        } else {
          card.style.display = "none";
        }
      });

      // Show/hide categories that have visible tools
      categorySections.forEach((section) => {
        const visibleTools = section.querySelectorAll(
          '.tool-card[style*="display: block"]',
        );
        const isDefaultState = query.trim() === "" && activeStatus === "all";
        const hasVisibleTools = visibleTools.length > 0 || isDefaultState;

        if (hasVisibleTools) {
          section.style.display = "block";
        } else {
          section.style.display = "none";
        }
      });

      // Handle "No results" message
      let noResultsMsg = document.getElementById("no-results-msg");
      const anyVisible = Array.from(toolCards).some(
        (card) => card.style.display !== "none",
      );

      if (!anyVisible && (query.trim() !== "" || activeStatus !== "all")) {
        if (!noResultsMsg && toolsContainer) {
          noResultsMsg = document.createElement("div");
          noResultsMsg.id = "no-results-msg";
          noResultsMsg.className = "text-center py-16 w-full";
          noResultsMsg.innerHTML = `
            <p class="text-4xl mb-4">🔍</p>
            <p class="text(--text-primary) font-semibold">No tools found</p>
            <p class="text(--text-secondary) mt-2">Try a different search term or filter.</p>
          `;
          toolsContainer.appendChild(noResultsMsg);
        } else if (noResultsMsg) {
          noResultsMsg.style.display = "block";
        }
      } else if (noResultsMsg) {
        noResultsMsg.style.display = "none";
      }
    }, 50);

    // Initial setup for filter buttons
    if (filterBtns) {
      filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          // Update active styling
          filterBtns.forEach((b) => {
            b.classList.remove(
              "bg-[var(--surface-elevated)]",
              "text(--text-primary)",
              "border-[var(--border-default)]",
            );
            b.classList.add(
              "bg-transparent",
              "text(--text-secondary)",
              "border-transparent",
            );
          });
          btn.classList.add(
            "bg-[var(--surface-elevated)]",
            "text(--text-primary)",
            "border-[var(--border-default)]",
          );
          btn.classList.remove(
            "bg-transparent",
            "text(--text-secondary)",
            "border-transparent",
          );

          activeStatus = btn.getAttribute("data-status") || "all";
          handleSearch();
        });
      });
    }

    if (searchInput) {
      searchInput.addEventListener("input", handleSearch);

      // Clear search on 'esc'
      searchInput.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          searchInput.value = "";
          handleSearch();
          searchInput.blur();
        }
      });

      // Keyboard shortcut ⌘K or Ctrl+K to focus search
      window.addEventListener("keydown", (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          searchInput.scrollIntoView();
          searchInput.focus();
        }
      });
    }
  </script>

  <!-- Search hint platform detection -->
  <script>
    const searchHint = document.getElementById("search-hint");

    if (searchHint) {
      const isMac = /Mac|iPhone|iPad|iPod/i.test(navigator.userAgent);
      searchHint.textContent = isMac ? "⌘K" : "Ctrl+K";
    }
  </script>

  <!-- Sliding pill effect -->
  <script>
    function initStatusFilter(): void {
      const group = document.getElementById("status-filter-group");
      const pill = document.getElementById("filter-pill");

      if (!group || !pill) return;

      const buttons = Array.from(
        group.querySelectorAll<HTMLButtonElement>(".status-filter-btn"),
      );

      function movePillTo(btn: HTMLButtonElement): void {
        const groupRect = group!.getBoundingClientRect();
        const btnRect = btn.getBoundingClientRect();

        pill!.style.left = `${btnRect.left - groupRect.left + group!.scrollLeft}px`;
        pill!.style.top = `${btnRect.top - groupRect.top + group!.scrollTop}px`;
        pill!.style.width = `${btnRect.width}px`;
        pill!.style.height = `${btnRect.height}px`;
      }

      function setActive(btn: HTMLButtonElement): void {
        buttons.forEach((b) => {
          b.classList.remove("text-(--text-primary)");
          b.classList.add("text-(--text-secondary)");
        });
        btn.classList.remove("text-(--text-secondary)");
        btn.classList.add("text-(--text-primary)");
        movePillTo(btn);
      }

      // Set initial state (no transition on first paint)
      pill.style.transition = "none";
      const initial = buttons[0];
      if (initial) {
        setActive(initial);
      }

      // Re-enable transition after initial placement
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          pill.style.transition =
            "left 300ms cubic-bezier(0.4,0,0.2,1), top 300ms cubic-bezier(0.4,0,0.2,1), width 300ms cubic-bezier(0.4,0,0.2,1), height 300ms cubic-bezier(0.4,0,0.2,1)";
        });
      });

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => setActive(btn));
      });

      // Recalculate on resize so the pill doesn't drift
      const observer = new ResizeObserver(() => {
        const active = buttons.find((b) =>
          b.classList.contains("text-(--text-primary)"),
        );
        if (active) {
          pill!.style.transition = "none";
          movePillTo(active);
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              pill!.style.transition = "";
            });
          });
        }
      });

      observer.observe(group);
    }

    // Works with Astro's view transitions too
    document.addEventListener("astro:page-load", initStatusFilter);
    initStatusFilter();
  </script>
</BaseLayout>
