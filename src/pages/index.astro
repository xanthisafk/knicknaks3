---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllTools,
  getActiveCategories,
  getToolsByCategory,
  getFeaturedToolsForCategory,
  getCategoryMeta,
} from "@/tools/_registry";
import { CATEGORY_INFO } from "@/tools/_types";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import ToolCard from "@/components/advanced/ToolCard.astro";

const allTools = getAllTools();
const activeCategories = getActiveCategories();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Knicknaks",
  description: "Free, offline-capable web app with useful day-to-day tools.",
  url: Astro.site?.toString(),
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---

<BaseLayout title="Knicknaks" structuredData={structuredData}>
  <div class="min-h-screen flex flex-col">
    <Header activeTab="tools" />

    <main class="flex-1">
      <section class="py-16 md:py-24 text-center relative">
        <div class="relative z-10 max-w-3xl mx-auto px-4">
          <h1
            class="text-4xl md:text-6xl font-extrabold mb-4"
            style="font-family: var(--font-heading); color: var(--text-primary)"
          >
            Your go-to <span class="doodle-underline text-primary-500"
              >Toolbox</span
            >
          </h1>
          <p
            class="text-lg md:text-xl my-8 max-w-xl mx-auto"
            style="color: var(--text-secondary)"
          >
            Free, fast, and privacy-friendly tools that run entirely in your
            browser. No signup. No tracking. No nonsense.
          </p>

          <!-- Search Trigger -->
          <div class="relative max-w-md mx-auto mb-6">
            <button
              type="button"
              onclick="window.dispatchEvent(new CustomEvent('open-command-palette'))"
              class="w-full text-left px-4 py-3 pl-10 rounded-xl border text-base cursor-pointer transition-colors"
              style="background: var(--surface-elevated); color: var(--text-tertiary); border-color: var(--border-default)"
            >
              Search for a tool, description or tag...
            </button>
            <span
              class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none font-emoji"
              style="color: var(--text-tertiary)">🔍</span
            >
            <div
              class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none"
            >
              <span
                id="search-hint"
                class="hidden sm:block text-xs font-bold px-2 py-1 border rounded-md"
                style="color: var(--text-tertiary); border-color: var(--border-default); background: var(--surface-bg)"
                >⌘K</span
              >
            </div>
          </div>
        </div>
      </section>

      <hr class="doodle-divider max-w-full mx-auto" />

      <!-- Category Previews -->
      <section class="pb-16 md:pb-24" id="tools">
        <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
          {
            activeCategories.length > 0 ? (
              activeCategories.map((category) => {
                const info = getCategoryMeta(category);
                const previewTools = getFeaturedToolsForCategory(category, 3);
                const allCatTools = getToolsByCategory(category);
                const totalCount = allCatTools.length;
                return (
                  <div
                    class="mb-12 category-section"
                    id={`category-${category}`}
                    data-category={category}
                  >
                    <div class="mb-6">
                      <a
                        href={`/tools/${category}`}
                        class="text-2xl font-bold flex items-center gap-2 no-underline hover:opacity-80 transition-opacity"
                        style={`font-family: var(--font-heading); color: var(--text-primary)`}
                      >
                        <span class="font-emoji">{info.icon}</span>
                        {info.label}
                        <span
                          class="text-sm font-normal"
                          style="color: var(--text-tertiary)"
                        >
                          →
                        </span>
                      </a>
                      <p
                        class="text-sm mt-1"
                        style="color: var(--text-secondary)"
                      >
                        {info.description}
                      </p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                      {previewTools.map((tool) => (
                        <ToolCard tool={tool} previewOnly={true} />
                      ))}
                      {/* "View all" card */}
                      <a
                        href={`/tools/${category}`}
                        class="group flex flex-col items-center justify-center p-5 rounded-lg border border-dashed no-underline transition-colors"
                        style="border-color: var(--border-default); color: var(--text-secondary); background: var(--surface-bg)"
                      >
                        <span class="text-3xl mb-2 font-emoji">{info.icon}</span>
                        <span class="font-semibold text-sm" style="color: var(--text-primary)">
                          View all {totalCount} tools →
                        </span>
                      </a>
                    </div>
                  </div>
                );
              })
            ) : (
              <div class="text-center py-16">
                <p class="text-4xl mb-4">🧰</p>
                <p style="color: var(--text-secondary)">
                  Tools are being crafted. Check back soon!
                </p>
              </div>
            )
          }
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<!-- Search hint: platform detection -->
<script>
  const hint = document.getElementById("search-hint");
  if (hint) {
    hint.textContent = /Mac|iPhone|iPad|iPod/i.test(navigator.userAgent)
      ? "⌘K"
      : "Ctrl+K";
  }
</script>
