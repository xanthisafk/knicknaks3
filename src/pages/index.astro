---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getAllTools,
  getToolsByCategory,
  getActiveCategories,
} from "@/tools/_registry";
import { CATEGORY_INFO, TOOL_STATUSES, STATUS_INFO } from "@/tools/_types";
import pkg from "../../package.json";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";

const allTools = getAllTools();
const activeCategories = getActiveCategories();

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Knicknaks",
  description: "Free, offline-capable web app with useful day-to-day tools.",
  url: Astro.site?.toString(),
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
};
---

<BaseLayout title="Knicknaks" structuredData={structuredData}>
  <div class="min-h-screen flex flex-col">
    <!-- Header -->
    <Header activeTab="tools" />

    <main class="flex-1">
      <!-- Hero Section -->
      <section class="py-16 md:py-24 text-center">
        <div class="max-w-3xl mx-auto px-4">
          <h1
            class="text-4xl md:text-6xl font-extrabold mb-4 text(--text-primary)"
            style="font-family: var(--font-heading)"
          >
            Your go-to <span class="doodle-underline">toolbox</span>
          </h1>
          <p
            class="text-lg md:text-xl text(--text-secondary) mb-8 max-w-xl mx-auto"
          >
            Free, fast, and privacy-friendly tools that run entirely in your
            browser. No signup. No tracking. No nonsense.
          </p>

          <!-- Search -->
          <div class="relative max-w-md mx-auto mb-6">
            <input
              id="tool-search"
              type="search"
              placeholder="⌘K or Ctrl+K"
              autocomplete="off"
              class="w-full px-4 py-3 pl-10 rounded-[var(--radius-xl)] bg-[var(--surface-elevated)] text(--text-primary) border border-[var(--border-default)] placeholder:text-[var(--text-tertiary)] shadow-sm focus:outline-none focus:border-[var(--border-focus)] focus:ring-2 focus:ring-[var(--ring-color)] text-base"
            />
            <span
              class="absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-tertiary)]"
              >🔍</span
            >
          </div>

          <!-- Status Filters -->
          <div
            class="flex flex-wrap items-center justify-center gap-2 max-w-2xl mx-auto"
          >
            <button
              class="status-filter-btn px-3 py-1.5 rounded-[var(--radius-full)] text-sm font-medium border transition-colors bg-[var(--surface-elevated)] text(--text-primary) border-[var(--border-default)] hover:border-[var(--border-hover)]"
              data-status="all"
            >
              All Tools
            </button>
            {
              TOOL_STATUSES.map((status) => {
                const info = STATUS_INFO[status];
                return (
                  <button
                    class="status-filter-btn px-3 py-1.5 rounded-[var(--radius-full)] text-sm font-medium border transition-colors bg-transparent text(--text-secondary) border-transparent hover:bg-[var(--surface-secondary)] hover:text(--text-primary)"
                    data-status={status}
                  >
                    <span class="mr-1">{info.icon}</span>
                    {info.label}
                  </button>
                );
              })
            }
          </div>
        </div>
      </section>

      <hr class="doodle-divider max-w-full mx-auto" />

      <!-- Tool Grid -->
      <section class="pb-16 md:pb-24" id="tools">
        <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8">
          {
            activeCategories.length > 0 ? (
              activeCategories.map((category) => {
                const categoryTools = getToolsByCategory(category);
                const info = CATEGORY_INFO[category];
                return (
                  <div
                    class="mb-12 category-section"
                    id={`category-${category}`}
                    data-category={category}
                  >
                    <div class="mb-6">
                      <h2
                        class="text-2xl font-bold text(--text-primary) flex items-center gap-2"
                        style="font-family: var(--font-heading)"
                      >
                        <span>{info.icon}</span>
                        {info.label}
                      </h2>
                      <p class="text-sm text(--text-secondary) mt-1">
                        {info.description}
                      </p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                      {categoryTools.map((tool) => (
                        <a
                          href={`/tools/${tool.slug}`}
                          class="group flex flex-col p-4 md:p-5 rounded-[var(--radius-lg)] bg-[var(--surface-elevated)] border border-[var(--border-default)] no-underline transition-all duration-150 hover:border-[var(--border-hover)] hover:shadow-md hover:-translate-y-0.5 tool-card relative overflow-visible"
                          data-tool-slug={tool.slug}
                          data-tool-status={tool.status || ""}
                        >
                          {/* Bookmark ribbon — peeks out from the top-right corner */}
                          {tool.status && (
                            <div class="absolute -top-px -right-px flex flex-col items-center pointer-events-none">
                              {/* Ribbon body */}
                              <div class="flex items-center justify-center gap-1 px-2 pt-1.5 pb-0 bg-[var(--surface-secondary)] border border-b-0 border-[var(--border-default)] rounded-tl-sm rounded-tr-[var(--radius-lg)] min-w-[44px]">
                                <span class="text-[11px] leading-none">
                                  {STATUS_INFO[tool.status].icon}
                                </span>
                                <span class="text-[9px] uppercase font-bold tracking-widest text(--text-secondary) leading-none">
                                  {STATUS_INFO[tool.status].label}
                                </span>
                              </div>
                              {/* Notched arrow tip — inward V cut using border trick */}
                              <div
                                class="w-full"
                                style="
                            height: 8px;
                            background: var(--surface-secondary);
                            border-left: 1px solid var(--border-default);
                            border-right: 1px solid var(--border-default);
                            clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 50% 55%, 0% 100%);
                          "
                              />
                            </div>
                          )}

                          {/* Card content — flex-col + flex-1 ensures uniform height */}
                          <div class="flex items-start gap-3 flex-1">
                            <span class="text-2xl flex-shrink-0 mt-0.5">
                              {tool.icon}
                            </span>
                            <div>
                              <h3
                                class="text-sm font-semibold text(--text-primary) group-hover:text-[var(--color-primary-600)]"
                                style="font-family: var(--font-heading)"
                              >
                                {tool.name}
                              </h3>
                              <p class="text-xs text(--text-secondary) mt-1 line-clamp-2">
                                {tool.description}
                              </p>
                            </div>
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                );
              })
            ) : (
              <div class="text-center py-16">
                <p class="text-4xl mb-4">🧰</p>
                <p class="text(--text-secondary)">
                  Tools are being crafted. Check back soon!
                </p>
              </div>
            )
          }
        </div>
      </section>
    </main>

    <!-- Footer -->
    <Footer />
  </div>

  <script>
    import { searchTools } from "@/lib/search";
    import { debounce } from "@/lib/utils";

    const searchInput = document.getElementById(
      "tool-search",
    ) as HTMLInputElement;
    const toolCards = document.querySelectorAll(
      ".tool-card",
    ) as NodeListOf<HTMLElement>;
    const categorySections = document.querySelectorAll(
      ".category-section",
    ) as NodeListOf<HTMLElement>;
    const toolsContainer = document.getElementById("tools");
    const filterBtns = document.querySelectorAll(
      ".status-filter-btn",
    ) as NodeListOf<HTMLButtonElement>;

    let activeStatus = "all";

    const handleSearch = debounce(() => {
      const query = searchInput ? searchInput.value : "";
      const results = query.trim() !== "" ? searchTools(query) : [];
      const resultSlugs = new Set(results.map((t) => t.slug));

      // Show/hide tools
      toolCards.forEach((card) => {
        const slug = card.getAttribute("data-tool-slug");
        const status = card.getAttribute("data-tool-status");

        const matchesSearch =
          query.trim() === "" || (slug && resultSlugs.has(slug));
        const matchesStatus = activeStatus === "all" || status === activeStatus;

        if (matchesSearch && matchesStatus) {
          card.style.display = "block";
        } else {
          card.style.display = "none";
        }
      });

      // Show/hide categories that have visible tools
      categorySections.forEach((section) => {
        const visibleTools = section.querySelectorAll(
          '.tool-card[style*="display: block"]',
        );
        const isDefaultState = query.trim() === "" && activeStatus === "all";
        const hasVisibleTools = visibleTools.length > 0 || isDefaultState;

        if (hasVisibleTools) {
          section.style.display = "block";
        } else {
          section.style.display = "none";
        }
      });

      // Handle "No results" message
      let noResultsMsg = document.getElementById("no-results-msg");
      const anyVisible = Array.from(toolCards).some(
        (card) => card.style.display !== "none",
      );

      if (!anyVisible && (query.trim() !== "" || activeStatus !== "all")) {
        if (!noResultsMsg && toolsContainer) {
          noResultsMsg = document.createElement("div");
          noResultsMsg.id = "no-results-msg";
          noResultsMsg.className = "text-center py-16 w-full";
          noResultsMsg.innerHTML = `
            <p class="text-4xl mb-4">🔍</p>
            <p class="text(--text-primary) font-semibold">No tools found</p>
            <p class="text(--text-secondary) mt-2">Try a different search term or filter.</p>
          `;
          toolsContainer.appendChild(noResultsMsg);
        } else if (noResultsMsg) {
          noResultsMsg.style.display = "block";
        }
      } else if (noResultsMsg) {
        noResultsMsg.style.display = "none";
      }
    }, 50);

    // Initial setup for filter buttons
    if (filterBtns) {
      filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          // Update active styling
          filterBtns.forEach((b) => {
            b.classList.remove(
              "bg-[var(--surface-elevated)]",
              "text(--text-primary)",
              "border-[var(--border-default)]",
            );
            b.classList.add(
              "bg-transparent",
              "text(--text-secondary)",
              "border-transparent",
            );
          });
          btn.classList.add(
            "bg-[var(--surface-elevated)]",
            "text(--text-primary)",
            "border-[var(--border-default)]",
          );
          btn.classList.remove(
            "bg-transparent",
            "text(--text-secondary)",
            "border-transparent",
          );

          activeStatus = btn.getAttribute("data-status") || "all";
          handleSearch();
        });
      });
    }

    if (searchInput) {
      searchInput.addEventListener("input", handleSearch);

      // Clear search on 'esc'
      searchInput.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
          searchInput.value = "";
          handleSearch();
          searchInput.blur();
        }
      });

      // Keyboard shortcut ⌘K or Ctrl+K to focus search
      window.addEventListener("keydown", (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          searchInput.focus();
        }
      });
    }
  </script>
</BaseLayout>
