---
import "@/styles/global.css";
import "@/styles/doodles.css";
import GlobalPalette from "@/components/layout/GlobalPalette";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  structuredData?: object;
}

const {
  title,
  description = "Free, offline-capable web app with useful day-to-day tools. No signup, no tracking, no BS.",
  ogImage = "/og-default.png",
  canonicalUrl,
  structuredData,
} = Astro.props;

const siteName = "Knicknaks";
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonical = canonicalUrl ?? Astro.url.href;

import { getCollection } from "astro:content";
const isBlog = Astro.url.pathname.startsWith("/blog");
let searchPosts: any[] = [];
if (isBlog) {
  try {
    const posts = await getCollection("blog");
    searchPosts = posts.map((post) => ({
      id: post.id,
      title: post.data.title,
      description: post.data.description,
      tags: post.data.tags,
    }));
  } catch (e) {
    console.error(e);
  }
}
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Theme initialization (prevent FOUC) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("knicknaks-theme");
        const pref =
          stored ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.dataset.theme = pref;
      })();
    </script>

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap&family=Noto+Color+Emoji&display=swap&family=Gloria+Hallelujah&display=swap"
      rel="stylesheet"
    />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#fcf7f8" id="meta-theme-color" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Structured Data -->
    {
      structuredData && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(structuredData)}
        />
      )
    }
  </head>
  <body>
    <slot />

    <GlobalPalette client:load blogPosts={searchPosts} isBlog={isBlog} />

    <!-- Service Worker Registration -->
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => {});
        });
      }
    </script>
  </body>
</html>
